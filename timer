# ----------------------------- Project Constants -----------------------------
APP_NAME="timer"           # ← HARDCODED - Required for curl | sh install
VERSION="2.1.2"
DESCRIPTION="Lightweight per-user named timers (volatile or persistent)"

# Repository source (used for self-update / installation)
REPO_BASE_URL="https://raw.githubusercontent.com/Wilgat/timer/main"
SCRIPT_URL="${REPO_BASE_URL}/${APP_NAME}"

# ----------------------------- Safe Variable Defaults ------------------------
: "${GLOBAL_BIN:=/usr/local/bin}"
: "${USER_BIN:=${HOME}/.local/bin}"
: "${INSTALL_PATH:=${GLOBAL_BIN}/${APP_NAME}}"

# ----------------------------- Root Detection --------------------------------
if [ -z "${IS_ROOT:-}" ]; then
    if [ "$(id -u)" -eq 0 ]; then
        IS_ROOT=1
    else
        IS_ROOT=0
    fi
fi

# ----------------------------- Force Flags & Quiet Mode ----------------------
: "${FORCE_USER:=0}"
: "${FORCE_GLOBAL:=0}"
: "${FORCE_REINSTALL:=0}"
: "${QUIET:=0}"

# ----------------------------- Color Output (Non-interactive Safe) -----------
if [ -t 1 ] && [ "${QUIET}" -eq 0 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' NC=''
fi

USERNAME="$(id -un 2>/dev/null || echo "unknown")"

# ----------------------------- Timer Storage Directories ---------------------
VOLATILE_DIR="/dev/shm"
PERSISTENT_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/timer"

# ----------------------------- POSIX-safe logging functions ------------------
info()    { [ "${QUIET}" -eq 0 ] && printf "${GREEN}[INFO]${NC} %s\n" "$*"; }
warn()    { [ "${QUIET}" -eq 0 ] && printf "${YELLOW}[WARN]${NC} %s\n" "$*" >&2 || true; }
error()   { printf "${RED}[ERROR]${NC} %s\n" "$*" >&2; }
success() { [ "${QUIET}" -eq 0 ] && printf "${GREEN}[OK]${NC} %s\n" "$*"; }

# =============================================================================
# get_timer_file() - Return full path to timer file
# =============================================================================
get_timer_file() {
    local name="$1"
    local mode="$2"
    local base_dir

    if [ "$mode" = "persistent" ]; then
        base_dir="$PERSISTENT_DIR"
        mkdir -p "$base_dir" 2>/dev/null || true
    else
        base_dir="$VOLATILE_DIR"
    fi

    echo "${base_dir}/timer_${USERNAME}_${name}"
}

# =============================================================================
# list_timers() - List all running timers for current user
# =============================================================================
list_timers() {
    local mode="$1"
    local base_dir found name start_time current_time elapsed minutes seconds file

    if [ "$mode" = "persistent" ]; then
        base_dir="$PERSISTENT_DIR"
    else
        base_dir="$VOLATILE_DIR"
    fi

    if [ ! -d "$base_dir" ]; then
        echo "No running timers found."
        return 0
    fi

    found=0
    for file in "${base_dir}"/timer_"${USERNAME}"_*; do
        [ -f "$file" ] || continue
        found=1
        name="${file##*timer_${USERNAME}_}"
        start_time=$(cat "$file" 2>/dev/null) || continue
        current_time=$(date +%s 2>/dev/null) || continue
        elapsed=$((current_time - start_time))
        minutes=$((elapsed / 60))
        seconds=$((elapsed % 60))
        printf "${GREEN}%-12s${NC} running for %02d min %02d sec\n" "$name" "$minutes" "$seconds"
    done

    [ "$found" -eq 0 ] && echo "No running timers found."
}

# =============================================================================
# get_installed_version() - Extract version from installed binary
# =============================================================================
#
# GENERAL PURPOSE:
# Safely reads the VERSION constant from the installed timer script.
# Used by --version-check and --self-update.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Designed to be reusable in other Wilgat projects.
# =============================================================================
get_installed_version() {
    local bin_path
    if [ "$IS_ROOT" -eq 1 ] || [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; then
        bin_path="${GLOBAL_BIN}/${APP_NAME}"
    else
        bin_path="${USER_BIN}/${APP_NAME}"
    fi

    if [ -x "$bin_path" ]; then
        grep '^VERSION="' "$bin_path" 2>/dev/null | cut -d'"' -f2 || echo "unknown"
    else
        echo "not installed"
    fi
}

# =============================================================================
# version_check() - Compare local vs remote version + suggest install
# =============================================================================
#
# GENERAL PURPOSE:
# Fetches the latest version from GitHub raw and compares with installed one.
# If not installed and running in interactive terminal, it suggests installation.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# =============================================================================
version_check() {
    info "Checking latest version of ${APP_NAME}..."

    local remote_version
    remote_version=$(curl -fsSL "${SCRIPT_URL}" 2>/dev/null | grep '^VERSION="' | cut -d'"' -f2 || echo "")

    if [ -z "$remote_version" ]; then
        error "Failed to fetch remote version"
        return 1
    fi

    local local_version
    local_version=$(get_installed_version)

    printf "Local version : %s\n" "$local_version"
    printf "Latest version: %s\n\n" "$remote_version"

    if [ "$local_version" = "$remote_version" ]; then
        success "You are running the latest version."
    else
        warn "A newer version is available (${remote_version})"
    fi
}

