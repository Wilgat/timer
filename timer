# =============================================================================
# app_main() - Main entrypoint and command dispatcher
# =============================================================================
#
# GENERAL PURPOSE:
# Thin dispatcher for the timer CLI (selfmanaged Type 0 + timer domain).
# Handles:
#   - Auto-install behavior for classic `curl | sh` one-liner (zero arguments)
#   - Global flag parsing (--quiet, --json, --debug, --force)
#   - Command routing for all Type 0 self-management commands
#
# This is the single entry point when the script is executed directly.
#
# CIAO PRINCIPLES APPLIED:
# - Caution (Principle 1): Never call undefined functions. Always use inst_is_installed.
#   Auto-install block is kept at the very top as required by existing comments.
# - Intentional (Principle 2): All supported commands from
#   requirement-shell-cli-interface.md and app_help() are recognized and routed.
# - Anti-fragile (Principle 3): Works correctly in interactive TTY, quiet, JSON,
#   and non-interactive `curl | sh` environments.
# - Over-protect (Principle 18): Explicit if/then logic, safe defaults, and centralized
#   output via out_die for unknown commands.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# This is the central command dispatcher. Changes here affect every execution path.
#
# Lessons Learned (CIAO Reflection):
# 2026-06-26:
#   - Original version called non-existent functions and only recognized
#     version/about/help; expanded routing and safe defaults.
# 2026-07-12:
#   - Wired --force → FORCE=1 and FORCE_REINSTALL=1 (requirement-shell-cli-interface).
# 2026-07-14:
#   - version routes through app_version (no dual inline path).
#   - zero-arg install propagates failure exit status.
#   - Type O empty argv: always install-ensure (not help when already installed).
#     Cases A/B/C (not installed / local / global). --force only for deliberate
#     re-download/replace — not required for a second one-liner run.
#     SSOT: requirement-shell-cli-zero-arguments.md (selfmanaged = Type O).
#
# Last reviewed: 2026-07-14
# =============================================================================

app_main() {
    # --- Safe Variable Defaults ---
    : "${COMMAND:=help}"
    : "${QUIET:=0}"
    : "${JSON:=0}"
    : "${DEBUG:=0}"
    : "${FORCE:=0}"
    : "${FORCE_REINSTALL:=0}"

    # === ZERO-ARG = Type O install-ensure (curl | sh contract) ===
    # Product type: Type O (online-install) — not Type N help-default.
    # Empty argv always means "ensure installed", never help.
    # Cases: not installed | installed local | installed global
    # - not installed → install (TTY prompt via inst_maybe_install; non-TTY auto)
    # - already installed → success no-op (inst_perform_install); no --force required
    # - --force / FORCE_REINSTALL only for deliberate re-download/replace
    # Exit status must reflect install outcome (failed download/checksum → non-zero).
    # SSOT: docs/requirements/requirement-shell-cli-zero-arguments.md
    if [ $# -eq 0 ]; then
        if [ "${JSON}" -eq 1 ] || [ "${QUIET}" -eq 1 ]; then
            inst_perform_install
            exit $?
        elif inst_is_installed; then
            inst_perform_install
            exit $?
        else
            inst_maybe_install
            exit $?
        fi
    fi

    # Domain state for timer commands (safe defaults under set -u)
    : "${TIMER_NAME:=default}"
    : "${TIMER_PERSIST:=0}"
    : "${TIMER_FILE:=}"
    : "${STORAGE_MODE:=volatile}"

    # === Argument parsing: flags and commands (order-independent) ===
    # Timer name is a free token after a domain command is selected.
    while [ $# -gt 0 ]; do
        case "$1" in
            --quiet|-q) QUIET=1 ;;
            --json)     JSON=1; QUIET=1 ;;
            --debug)    DEBUG=1 ;;
            --force)    FORCE=1; FORCE_REINSTALL=1 ;;
            --persist)  TIMER_PERSIST=1 ;;
            version|about|help|version-check|self-update|self-uninstall|install)
                COMMAND="$1"
                ;;
            start|stop|status|list|kill|reset)
                COMMAND="$1"
                ;;
            *)
                # Free token: timer name when a domain command is active
                case "${COMMAND}" in
                    start|stop|status|list|kill|reset)
                        TIMER_NAME="$1"
                        ;;
                    *)
                        out_die "Unknown command or flag: $1. See '${APP_NAME} help'."
                        ;;
                esac
                ;;
        esac
        shift
    done

    # Export force into install/uninstall paths via globals already set
    out_debug "dispatch command=${COMMAND} quiet=${QUIET} json=${JSON} force=${FORCE} persist=${TIMER_PERSIST}"

    case "${COMMAND}" in
        version)
            app_version
            ;;
        about)
            app_about
            ;;
        version-check)
            ver_check
            ;;
        self-update)
            inst_self_update
            ;;
        self-uninstall)
            inst_self_uninstall
            ;;
        install)
            inst_perform_install
            ;;
        start|stop|status|list|kill|reset)
            timer_sanitize_name
            STORAGE_MODE="volatile"
            [ "${TIMER_PERSIST}" -eq 1 ] && STORAGE_MODE="persistent"
            TIMER_FILE=$(timer_get_file "$TIMER_NAME" "$STORAGE_MODE")
            case "${COMMAND}" in
                start)  timer_start ;;
                stop)   timer_stop ;;
                status) timer_status ;;
                list)   timer_list "$STORAGE_MODE" ;;
                kill)   timer_kill_or_reset kill ;;
                reset)  timer_kill_or_reset reset ;;
            esac
            ;;
        help|*)
            app_help
            ;;
    esac
}

