# =============================================================================
# resolve_app_base_dir() - Central storage resolver with full fallback
# =============================================================================
#
# SINGLE SOURCE OF TRUTH for all ${APP_NAME} storage decisions.
# Handles missing /dev/shm, missing $HOME, and ensures we always have
# a writable location or die() with clear message.
#
# Priority for volatile mode:
#   1. /dev/shm          (fastest, RAM)
#   2. /tmp              (standard fallback, almost always available)
#   3. /tmp/${APP_NAME}_${USERNAME}  (safe per-user subdir when $HOME is missing)
#
# For persistent mode: always tries XDG_CACHE_HOME → ~/.cache → /tmp/${APP_NAME}_${USERNAME}
#
# !!! DO NOT MODIFY OR DUPLICATE THIS LOGIC !!!
# All ${APP_NAME} functions must use this helper (via get_app_file or directly)
# to keep behavior 100% consistent.
# =============================================================================

resolve_app_base_dir() {
    local requested_mode="$1"
    local actual_mode="$requested_mode"
    local base_dir

    # === Volatile mode fallback chain ===
    if [ "$requested_mode" = "volatile" ]; then
        if [ -d "$VOLATILE_DIR" ] && [ -w "$VOLATILE_DIR" ]; then
            base_dir="$VOLATILE_DIR"
        elif [ -d "/tmp" ] && [ -w "/tmp" ]; then
            actual_mode="fallback"
            base_dir="/tmp"
            if [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ]; then
                warn "Volatile storage (/dev/shm) not available. Falling back to /tmp."
            fi
        else
            # Last resort: create a per-user subdirectory under /tmp
            base_dir="/tmp/${APP_NAME}_${USERNAME}"
            if ! mkdir -p "$base_dir" 2>/dev/null || [ ! -w "$base_dir" ]; then
                die "No writable temporary storage available (/dev/shm, /tmp). ${APP_NAME} cannot start."
            fi
            actual_mode="fallback"
            if [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ]; then
                warn "Volatile storage unavailable. Using fallback directory: $base_dir"
            fi
        fi
    else
        # === Persistent mode ===
        if [ -n "${HOME:-}" ] && [ -d "${HOME}" ] && [ -w "${HOME}" ]; then
            base_dir="${PERSISTENT_DIR}"
            mkdir -p "$base_dir" 2>/dev/null || true
        else
            # No usable $HOME → fallback to /tmp per-user directory
            base_dir="/tmp/${APP_NAME}_${USERNAME}_persistent"
            if ! mkdir -p "$base_dir" 2>/dev/null || [ ! -w "$base_dir" ]; then
                die "No writable location for persistent storage (no usable \$HOME and cannot write to /tmp). ${APP_NAME} cannot continue."
            fi
            if [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ]; then
                warn "No usable \$HOME detected. Persistent timers will use fallback directory: $base_dir"
            fi
        fi
    fi

    echo "$base_dir"
}

# =============================================================================
# get_app_file() - Return full path to timer file
# =============================================================================
#
# Uses the central resolve_app_base_dir() helper to guarantee consistent
# fallback behavior and warning across the entire script.
#
# Uses the same storage resolver logic (volatile + persistent with fallbacks).
# - volatile  → /dev/shm (fast, lost on reboot)
# - persistent → ~/.cache/timer (survives reboot)
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# It must remain a thin wrapper around the central resolver.
# =============================================================================

get_app_file() {
    local name="$1"
    local requested_mode="$2"
    local base_dir

    base_dir=$(resolve_app_base_dir "$requested_mode")

    # App filename format guarantees per-user isolation
    echo "${base_dir}/${APP_NAME}_${USERNAME}_${name}"
}

# =============================================================================
# sanitize_name() - Prevent dangerous characters in timer names
# =============================================================================
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Security / robustness measure for filename safety.
# =============================================================================

sanitize_name() {
    case "$NAME" in
        *[/\\:*?"<>|'\''"\`\$]*|*..*|*\$\(*|*${IFS}*)
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Invalid timer name: contains forbidden characters" "invalid_name"
            else
                error "Invalid timer name '${NAME}' (contains forbidden characters)"
            fi
            exit 1
            ;;
        "")
            NAME="default"
            ;;
    esac
}

# =============================================================================
# timer_start() - Start a new timer
# =============================================================================
#
# Uses atomic creation + proper existence check to avoid resetting running timers.
# Now correctly detects "already running" in both normal and --json mode.
#
# !!! DO NOT SIMPLIFY THIS LOGIC !!!
# =============================================================================

timer_start() {
    local mode="volatile"
    [ "$PERSIST" -eq 1 ] && mode="persistent"

    if [ -f "$APP_FILE" ]; then
        # Timer is already running
        if [ "${JSON}" -eq 1 ]; then
            output_json "error" "Timer '${NAME}' is already running." \
                "code" "already_running" \
                "name" "$NAME" \
                "mode" "$mode"
        else
            warn "Timer '${NAME}' is already running."
        fi
        exit 1
    fi

    # Create the timer file atomically (only if it doesn't exist)
    if ! date +%s > "$APP_FILE" 2>/dev/null; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "Cannot create timer file" "io_error"
        else
            error "Cannot create timer file."
        fi
        exit 1
    fi

    # Success
    if [ "${JSON}" -eq 1 ]; then
        output_json "success" "Timer '${NAME}' started." \
            "name" "$NAME" \
            "mode" "$mode"
    else
        success "Timer '${NAME}' started."
        [ "$PERSIST" -eq 1 ] && info "  (persistent mode)"
    fi
}

# =============================================================================
# timer_stop() - Stop a timer and show elapsed time
# =============================================================================
#
# Uses APP_FILE (which was resolved via get_app_file → central fallback).
# No additional fallback code needed here.
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# =============================================================================

timer_stop() {
    if [ ! -f "$APP_FILE" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "No timer '${NAME}' running." "no_timer"
        else
            warn "No timer '${NAME}' running."
        fi
        exit 1
    fi

    local start_time current_time elapsed minutes seconds
    start_time=$(cat "$APP_FILE" 2>/dev/null)
    rm -f "$APP_FILE"

    current_time=$(date +%s)
    elapsed=$((current_time - start_time))
    minutes=$((elapsed / 60))
    seconds=$((elapsed % 60))

    if [ "${JSON}" -eq 1 ]; then
        output_json "success" "Timer '${NAME}' stopped after ${minutes} min ${seconds} sec." \
            "name" "$NAME" \
            "minutes" "$minutes" \
            "seconds" "$seconds" \
            "elapsed" "$elapsed"
    else
        success "Timer '${NAME}' stopped after ${minutes} min ${seconds} sec."
    fi
}

# =============================================================================
# timer_status() - Show current elapsed time without stopping the timer
# =============================================================================
#
# Uses APP_FILE (resolved via central fallback logic).
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# =============================================================================

timer_status() {
    if [ ! -f "$APP_FILE" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json_error "No timer '${NAME}' running." "no_timer"
        else
            warn "No timer '${NAME}' running."
        fi
        exit 1
    fi

    local start_time current_time elapsed minutes seconds
    start_time=$(cat "$APP_FILE" 2>/dev/null)
    current_time=$(date +%s)
    elapsed=$((current_time - start_time))
    minutes=$((elapsed / 60))
    seconds=$((elapsed % 60))

    if [ "${JSON}" -eq 1 ]; then
        output_json "status" "Timer '${NAME}' running." \
            "name" "$NAME" \
            "minutes" "$minutes" \
            "seconds" "$seconds" \
            "elapsed" "$elapsed"
    else
        msg "Timer '${NAME}': ${minutes} min ${seconds} sec"
    fi
}

# =============================================================================
# list_timers() - List all running timers for current user
# =============================================================================
#
# Now uses the central resolve_app_base_dir() helper so it respects the
# exact same /dev/shm fallback as every other timer command.
# Only one "No running timers found." message is ever shown.
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# =============================================================================

list_timers() {
    local requested_mode="$1"
    local base_dir timers_json count=0 file name start_time current_time elapsed minutes seconds

    base_dir=$(resolve_app_base_dir "$requested_mode")

    if [ ! -d "$base_dir" ]; then
        if [ "${JSON}" -eq 1 ]; then
            output_json "list" "" "mode" "$requested_mode" "count" "0" "timers" "[]"
        else
            msg "No running timers found."
        fi
        return 0
    fi

    timers_json="["
    local first=true

    for file in "${base_dir}"/${APP_NAME}_"${USERNAME}"_*; do
        [ -f "$file" ] || continue

        name="${file##*${APP_NAME}_${USERNAME}_}"
        start_time=$(cat "$file" 2>/dev/null) || {
            rm -f "$file" 2>/dev/null || true
            continue
        }

        current_time=$(date +%s 2>/dev/null) || continue
        elapsed=$((current_time - start_time))
        minutes=$((elapsed / 60))
        seconds=$((elapsed % 60))

        if [ "$count" -gt 0 ]; then
            timers_json="${timers_json},"
        fi

        timers_json="${timers_json}{\"name\":\"${name}\",\"minutes\":${minutes},\"seconds\":${seconds},\"elapsed\":${elapsed}}"
        count=$((count + 1))
    done
    timers_json="${timers_json}]"

    if [ "${JSON}" -eq 1 ]; then
        output_json "list" "" \
            "mode" "$requested_mode" \
            "count" "$count" \
            "timers" "$timers_json"
    else
        if [ "$count" -eq 0 ]; then
            msg "No running timers found."
        else
            for file in "${base_dir}"/${APP_NAME}_"${USERNAME}"_*; do
                [ -f "$file" ] || continue
                name="${file##*${APP_NAME}_${USERNAME}_}"
                start_time=$(cat "$file" 2>/dev/null) || continue
                current_time=$(date +%s)
                elapsed=$((current_time - start_time))
                minutes=$((elapsed / 60))
                seconds=$((elapsed % 60))
                msg "${name} running for ${minutes} min ${seconds} sec"
            done
        fi
    fi
}

# =============================================================================
# Main script starts here
# =============================================================================
#
# IMPORTANT:
# This main() function is intentionally kept as the single entry point and
# command dispatcher. All business logic lives in dedicated functions
# (timer_start, timer_stop, timer_status, list_timers, resolve_app_base_dir,
# show_about, etc.).
#
# This design allows us to focus on refactoring or adding features in one
# isolated place instead of hunting through the whole script.
#
# !!! DO NOT REMOVE OR SIMPLIFY THIS COMMENT !!!
# It serves as a strong reminder for future maintenance (including when AI
# assistants try to "clean up" the code).
# =============================================================================

main_timer() {
    local cmd="help"
    local NAME="default"
    local PERSIST=0

    # === AUTO-INSTALL FOR ONE-LINER (curl | sh) ===
    # This block MUST stay at the very top, before any argument parsing.
    # It ensures that `curl ... | sh` actually installs the tool instead of
    # just showing help and exiting with "command not found".
    #
    # perform_self_install / maybe_install is important here EVEN THOUGH
    # a subcommand may be present later, because the main real-world usage
    # of this script is the one-liner installer. Installing first is the
    # expected behavior in that context.
    if ! is_installed && [ $# -eq 0 ]; then
        if [ "${JSON}" -eq 1 ] || [ "${QUIET}" -eq 1 ]; then
            # Non-interactive / JSON mode → install silently
            perform_self_install
        else
            maybe_install
        fi
        exit 0
    fi

    # === Phase 1: Parse all arguments (flags first, then command + name) ===
    while [ $# -gt 0 ]; do
        case "$1" in
            --persist)
                PERSIST=1
                ;;
            --quiet|-q)
                QUIET=1
                ;;
            --json)
                JSON=1
                QUIET=1
                ;;
            help|version|--version|-v|version-check|--version-check|self-update|--self-update)
                cmd="${1#--}"
                ;;
            self-uninstall|--self-uninstall)
                cmd="self-uninstall"
                ;;
            reinstall|--reinstall|--force)
                FORCE_REINSTALL=1
                ;;
            about)
                cmd="about"
                ;;
            start|stop|status|list|kill|reset)
                cmd="$1"
                ;;
            *)
                # Everything else is treated as timer name (only for timer commands)
                if [ "$cmd" = "start" ] || [ "$cmd" = "stop" ] || \
                   [ "$cmd" = "status" ] || [ "$cmd" = "kill" ] || [ "$cmd" = "reset" ] || \
                   [ "$cmd" = "list" ]; then
                    NAME="$1"
                else
                    if [ "${JSON}" -eq 1 ]; then
                        output_json_error "Unknown argument: $1" "bad_argument"
                    else
                        error "Unknown argument: $1"
                        msg "Use '${APP_NAME} help' for available commands."
                    fi
                    exit 1
                fi
                ;;
        esac
        shift
    done

    # === Sanitize timer NAME (only if it's a timer operation) ===
    if [ "$cmd" = "start" ] || [ "$cmd" = "stop" ] || [ "$cmd" = "status" ] || \
       [ "$cmd" = "kill" ] || [ "$cmd" = "reset" ] || [ "$cmd" = "list" ] ; then
        sanitize_name
    fi

    # Determine storage mode and timer file path
    local STORAGE_MODE APP_FILE
    STORAGE_MODE=$([ "$PERSIST" -eq 1 ] && echo "persistent" || echo "volatile")
    APP_FILE=$(get_app_file "$NAME" "$STORAGE_MODE")

    # === Dispatch commands ===
    case "$cmd" in
        version)
            if [ "${JSON}" -eq 1 ]; then
                output_json "version" "app" "${APP_NAME}" "version" "${VERSION}"
            else
                msg "${APP_NAME} version ${VERSION}"
            fi
            ;;

        version-check)
            version_check
            exit 0 ;;

        self-update)
            self_update
            exit 0 ;;

        self-uninstall)
            self_uninstall
            exit 0 ;;

        help)
            show_timer_help
            exit 0 ;;

        about)
            show_about
            exit 0 ;;

        start)
            timer_start
            ;;

        stop)
            timer_stop
            ;;

        status)
            timer_status
            ;;

        kill|reset)
            if [ ! -f "$APP_FILE" ]; then
                if [ "${JSON}" -eq 1 ]; then
                    output_json_error "No timer '${NAME}' running." "no_timer"
                else
                    warn "No timer '${NAME}' running."
                fi
                exit 1
            fi
            rm -f "$APP_FILE"
            if [ "$cmd" = "reset" ]; then
                if [ "${JSON}" -eq 1 ]; then
                    output_json "success" "Timer '${NAME}' has been reset." "name" "$NAME"
                else
                    success "Timer '${NAME}' has been reset."
                fi
            else
                if [ "${JSON}" -eq 1 ]; then
                    output_json "success" "Timer '${NAME}' discarded." "name" "$NAME"
                else
                    warn "Timer '${NAME}' discarded."
                fi
            fi
            ;;

        list)
            list_timers "$STORAGE_MODE"
            ;;

        *)
            if [ "${JSON}" -eq 1 ]; then
                output_json_error "Unknown command: ${cmd}" "unknown_command"
            else
                error "Unknown command: ${cmd}"
                msg "Use '${APP_NAME} help' for available commands."
            fi
            exit 1
            ;;
    esac
}

main_timer "$@"