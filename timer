  ${APP_NAME} about                      Show diagnostic info (shell, install status, versions...)
  ${APP_NAME} version                    Show version
  ${APP_NAME} version-check              Compare with latest
  ${APP_NAME} self-update                Update to latest version
  ${APP_NAME} reinstall                  Force reinstall
  ${APP_NAME} help                       This help

Options:
  --persist           Store in persistent storage (survives reboot)
  --quiet, -q         Suppress non-error output
  --json              Output in machine-readable JSON format (implies --quiet)

New in 2.6.1:
  • 'about' subcommand with full environment diagnostics
  • Robust /dev/shm fallback (including no \$HOME cases using /tmp)
  • Centralized storage resolver for consistency
EOF
}

# =============================================================================
# resolve_timer_base_dir() - Central storage resolver with full fallback
# =============================================================================
#
# SINGLE SOURCE OF TRUTH for all timer storage decisions.
# Handles missing /dev/shm, missing $HOME, and ensures we always have
# a writable location or die() with clear message.
#
# Priority for volatile mode:
#   1. /dev/shm          (fastest, RAM)
#   2. /tmp              (standard fallback, almost always available)
#   3. /tmp/timer_${USERNAME}  (safe per-user subdir when $HOME is missing)
#
# For persistent mode: always tries XDG_CACHE_HOME → ~/.cache → /tmp/timer_${USERNAME}
#
# !!! DO NOT MODIFY OR DUPLICATE THIS LOGIC !!!
# All timer functions must use this helper (via get_timer_file or directly)
# to keep behavior 100% consistent.
# =============================================================================

resolve_timer_base_dir() {
    local requested_mode="$1"
    local actual_mode="$requested_mode"
    local base_dir

    # === Volatile mode fallback chain ===
    if [ "$requested_mode" = "volatile" ]; then
        if [ -d "$VOLATILE_DIR" ] && [ -w "$VOLATILE_DIR" ]; then
            base_dir="$VOLATILE_DIR"
        elif [ -d "/tmp" ] && [ -w "/tmp" ]; then
            actual_mode="fallback"
            base_dir="/tmp"
            if [ "${QUIET}" -eq 0 ]; then
                warn "Volatile storage (/dev/shm) not available. Falling back to /tmp."
            fi
        else
            # Last resort: create a per-user subdirectory under /tmp
            base_dir="/tmp/timer_${USERNAME}"
            if ! mkdir -p "$base_dir" 2>/dev/null || [ ! -w "$base_dir" ]; then
                die "No writable temporary storage available (/dev/shm, /tmp). Timer cannot start."
            fi
            actual_mode="fallback"
            if [ "${QUIET}" -eq 0 ]; then
                warn "Volatile storage unavailable. Using fallback directory: $base_dir"
            fi
        fi
    else
        # === Persistent mode ===
        if [ -n "${HOME:-}" ] && [ -d "${HOME}" ] && [ -w "${HOME}" ]; then
            base_dir="${PERSISTENT_DIR}"
            mkdir -p "$base_dir" 2>/dev/null || true
        else
            # No usable $HOME → fallback to /tmp per-user directory
            base_dir="/tmp/timer_${USERNAME}_persistent"
            if ! mkdir -p "$base_dir" 2>/dev/null || [ ! -w "$base_dir" ]; then
                die "No writable location for persistent storage (no usable \$HOME and cannot write to /tmp). Timer cannot continue."
            fi
            if [ "${QUIET}" -eq 0 ]; then
                warn "No usable \$HOME detected. Persistent timers will use fallback directory: $base_dir"
            fi
        fi
    fi

    echo "$base_dir"
}

# =============================================================================
# get_timer_file() - Return full path to timer file
# =============================================================================
#
# Uses the central resolve_timer_base_dir() helper to guarantee consistent
# fallback behavior and warning across the entire script.
#
# - volatile  → /dev/shm (fast, lost on reboot)
# - persistent → ~/.cache/timer (survives reboot)
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# It must remain a thin wrapper around the central resolver.
# =============================================================================

get_timer_file() {
    local name="$1"
    local requested_mode="$2"
    local base_dir

    base_dir=$(resolve_timer_base_dir "$requested_mode")

    # Timer filename format guarantees per-user isolation
    echo "${base_dir}/timer_${USERNAME}_${name}"
}

# =============================================================================
# timer_start() - Start a new timer
# =============================================================================
#
# Uses atomic file creation to eliminate race condition.
# Relies on get_timer_file() → resolve_timer_base_dir() for fallback.
#
# !!! DO NOT SIMPLIFY THIS LOGIC !!!
# The atomic pattern + error distinction is intentional.
# =============================================================================

timer_start() {
    # Attempt to create the timer file atomically (no TOCTOU race)
    if ! date +%s > "$TIMER_FILE" 2>/dev/null; then
        if [ -f "$TIMER_FILE" ]; then
            warn "Timer '${NAME}' is already running."
        else
            error "Cannot create timer file."
        fi
        exit 1
    fi

    success "Timer '${NAME}' started."
    [ "$PERSIST" -eq 1 ] && info "  (persistent mode)"
}

# =============================================================================
# timer_stop() - Stop a timer and show elapsed time
# =============================================================================
#
# Uses TIMER_FILE (which was resolved via get_timer_file → central fallback).
# No additional fallback code needed here.
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# =============================================================================

timer_stop() {
    if [ ! -f "$TIMER_FILE" ]; then
        warn "No timer '${NAME}' running."
        exit 1
    fi

    local start_time current_time elapsed minutes seconds
    start_time=$(cat "$TIMER_FILE" 2>/dev/null)
    rm -f "$TIMER_FILE"

    current_time=$(date +%s)
    elapsed=$((current_time - start_time))
    minutes=$((elapsed / 60))
    seconds=$((elapsed % 60))

    success "Timer '${NAME}' stopped after ${minutes} min ${seconds} sec."
}

# =============================================================================
# timer_status() - Show current elapsed time without stopping the timer
# =============================================================================
#
# Uses TIMER_FILE (resolved via central fallback logic).
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# =============================================================================

timer_status() {
    if [ ! -f "$TIMER_FILE" ]; then
        warn "No timer '${NAME}' running."
        exit 1
    fi

    local start_time current_time elapsed minutes seconds
    start_time=$(cat "$TIMER_FILE" 2>/dev/null)
    current_time=$(date +%s)
    elapsed=$((current_time - start_time))
    minutes=$((elapsed / 60))
    seconds=$((elapsed % 60))

    msg "Timer '${NAME}': ${minutes} min ${seconds} sec"
}

# =============================================================================
# list_timers() - List all running timers for current user
# =============================================================================
#
# Now uses the central resolve_timer_base_dir() helper so it respects the
# exact same /dev/shm fallback as every other timer command.
# Only one "No running timers found." message is ever shown.
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# =============================================================================

list_timers() {
    local requested_mode="$1"
    local base_dir found name start_time current_time elapsed minutes seconds file

    base_dir=$(resolve_timer_base_dir "$requested_mode")

    if [ ! -d "$base_dir" ]; then
        msg "No running timers found."
        return 0
    fi

    found=0
    for file in "${base_dir}"/timer_"${USERNAME}"_*; do
        [ -f "$file" ] || continue
        found=1
        name="${file##*timer_${USERNAME}_}"
        start_time=$(cat "$file" 2>/dev/null) || continue
        current_time=$(date +%s 2>/dev/null) || continue
        elapsed=$((current_time - start_time))
        minutes=$((elapsed / 60))
        seconds=$((elapsed % 60))
        msg "${name} running for ${minutes} min ${seconds} sec"
    done

    if [ "$found" -eq 0 ]; then
        msg "No running timers found."
    fi
}

# =============================================================================
# Main script starts here
# =============================================================================
#
# IMPORTANT:
# This main() function is intentionally kept as the single entry point and
# command dispatcher. All business logic lives in dedicated functions
# (timer_start, timer_stop, timer_status, list_timers, resolve_timer_base_dir,
# show_about, etc.).
#
# This design allows us to focus on refactoring or adding features in one
# isolated place instead of hunting through the whole script.
#
# !!! DO NOT REMOVE OR SIMPLIFY THIS COMMENT !!!
# It serves as a strong reminder for future maintenance (including when AI
# assistants try to "clean up" the code).
# =============================================================================

main() {
    local cmd="greet"
    local NAME="default"
    local PERSIST=0

    while [ $# -gt 0 ]; do
        case "$1" in
            --persist)                      PERSIST=1 ;;
            --quiet|-q)                     QUIET=1 ;;
            --json)                         JSON=1; QUIET=1 ;;   # --json implies and overrides quiet
            help)                           cmd="help" ;;
            version|--version|-v)           cmd="version" ;;
            version-check|--version-check)  cmd="version-check" ;;
            self-update|--self-update)      cmd="self-update" ;;
            reinstall|--force|--reinstall)  FORCE_REINSTALL=1 ;;
            about)                          cmd="about" ;;
            start|stop|status|list|kill|reset)
                cmd="$1" 
                ;;
            *)              
                NAME="$1" 
                ;;
        esac
        shift
    done

    # Check if tool needs to be installed first
    maybe_install

    # Determine storage mode and get timer file path
    local STORAGE_MODE TIMER_FILE
    STORAGE_MODE=$([ "$PERSIST" -eq 1 ] && echo "persistent" || echo "volatile")
    TIMER_FILE=$(get_timer_file "$NAME" "$STORAGE_MODE")

    case "$cmd" in
        greet)
            info "Timer!" ;;

        version)
            msg "${APP_NAME} version ${VERSION}" ;;

        version-check)
            version_check
            exit 0 ;;

        self-update)
            self_update
            exit 0 ;;

        help)
            show_timer_help
            exit 0 ;;

        about)
            show_about
            exit 0 ;;

        start)
            timer_start
            ;;

        stop)
            timer_stop
            ;;

        status)
            timer_status
            ;;

        kill|reset)
            if [ ! -f "$TIMER_FILE" ]; then
                warn "No timer '${NAME}' running."
                exit 1
            fi
            rm -f "$TIMER_FILE"
            if [ "$cmd" = "reset" ]; then
                success "Timer '${NAME}' has been reset."
            else
                warn "Timer '${NAME}' discarded."
            fi
            ;;

        list)
            list_timers "$STORAGE_MODE"
            ;;

        *)
            error "Unknown command: ${cmd}"
            msg "Use '${APP_NAME} help' for available commands."
            exit 1
            ;;
    esac
}

main "$@"