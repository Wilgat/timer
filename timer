# =============================================================================
# util_get_current_shell() - Detect current / parent shell name
# =============================================================================
#
# GENERAL PURPOSE:
# Returns a best-effort shell command name for diagnostics (about).
# Prefer parent shell when the current process is sh/dash/ash/the app itself.
#
# PRINTF EXCEPTION (class B – function return-via-stdout):
# Final printf '%s' "$shell" (and echo fallbacks inside $(…)) are data
# returns for capture by app_about — not product messages. Display uses out_*.
# See requirement-shell-output-requirements.md §2.1.1.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Nested functions are not portable POSIX; this must stay top-level.
#
# Last reviewed: 2026-07-12
# =============================================================================
util_get_current_shell() {
    local shell="unknown"
    shell=$(ps -p $$ -o comm= 2>/dev/null | tr -d '()' || echo "unknown")

    if [ "$shell" = "${APP_NAME}" ] || [ "$shell" = "sh" ] || \
       [ "$shell" = "dash" ] || [ "$shell" = "ash" ]; then
        local parent_pid
        parent_pid=$(ps -p $$ -o ppid= 2>/dev/null | tr -d ' ')
        if [ -n "$parent_pid" ]; then
            shell=$(ps -p "$parent_pid" -o comm= 2>/dev/null | tr -d '()' || echo "$shell")
        fi
    fi
    printf '%s' "$shell"
}


# =============================================================================
# DOMAIN: timer storage + commands (product specialization of selfmanaged bootstrap)
# =============================================================================
#
# GENERAL PURPOSE:
# Per-user named timers (volatile /dev/shm or persistent cache). All output goes
# through out_* SSOT. Architecture and lifecycle stay on inst_*/app_* from bootstrap.
#
# !!! DO NOT SIMPLIFY fallback chains or name sanitization !!!
# =============================================================================

timer_resolve_base_dir() {
    # --- Safe Variable Defaults ---
    local requested_mode="${1-volatile}"
    local actual_mode="$requested_mode"
    local base_dir
    : "${VOLATILE_DIR:=/dev/shm}"
    : "${APP_NAME:=timer}"
    : "${USERNAME:=unknown}"
    : "${HOME:=/tmp}"
    : "${QUIET:=0}"
    : "${JSON:=0}"
    : "${PERSISTENT_DIR:=${XDG_CACHE_HOME:-${HOME}/.cache}/${APP_NAME}}"

    if [ "$requested_mode" = "volatile" ]; then
        if [ -d "$VOLATILE_DIR" ] && [ -w "$VOLATILE_DIR" ]; then
            base_dir="$VOLATILE_DIR"
        elif [ -d "/tmp" ] && [ -w "/tmp" ]; then
            actual_mode="fallback"
            base_dir="/tmp"
            if [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ]; then
                out_warn "Volatile storage (/dev/shm) not available. Falling back to /tmp."
            fi
        else
            base_dir="/tmp/${APP_NAME}_${USERNAME}"
            if ! mkdir -p "$base_dir" 2>/dev/null || [ ! -w "$base_dir" ]; then
                out_die "No writable temporary storage available (/dev/shm, /tmp). ${APP_NAME} cannot start."
            fi
            actual_mode="fallback"
            if [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ]; then
                out_warn "Volatile storage unavailable. Using fallback directory: $base_dir"
            fi
        fi
    else
        if [ -n "${HOME-}" ] && [ -d "${HOME}" ] && [ -w "${HOME}" ]; then
            base_dir="${PERSISTENT_DIR}"
            mkdir -p "$base_dir" 2>/dev/null || true
        else
            base_dir="/tmp/${APP_NAME}_${USERNAME}_persistent"
            if ! mkdir -p "$base_dir" 2>/dev/null || [ ! -w "$base_dir" ]; then
                out_die "No writable location for persistent storage (no usable \$HOME and cannot write to /tmp). ${APP_NAME} cannot continue."
            fi
            if [ "${QUIET}" -eq 0 ] && [ "${JSON}" -eq 0 ]; then
                out_warn "No usable \$HOME detected. Persistent timers will use fallback directory: $base_dir"
            fi
        fi
    fi

    printf '%s\n' "$base_dir"
}

timer_get_file() {
    local name="${1-default}"
    local requested_mode="${2-volatile}"
    local base_dir
    : "${APP_NAME:=timer}"
    : "${USERNAME:=unknown}"
    base_dir=$(timer_resolve_base_dir "$requested_mode")
    printf '%s\n' "${base_dir}/${APP_NAME}_${USERNAME}_${name}"
}

timer_sanitize_name() {
    # Mutates global TIMER_NAME (set by app_main). Empty → default.
    # Filename-safe names only: reject path separators and shell metacharacters.
    # Note: complex bracket classes with nested quotes are unreliable across dash/ash —
    # use explicit glob arms (CIAO Caution / anti-fragile).
    : "${TIMER_NAME:=default}"
    case "$TIMER_NAME" in
        "")
            TIMER_NAME="default"
            ;;
        *..*|*'/'*|*'\\'*|*':'*|*'*'*|*'?'*|*'"'*|*"'"*|*'<'*|*'>'*|*'|'*|*'`'*|*'$'*|*' '*|*$(printf '\t')*)
            if [ "${JSON:-0}" -eq 1 ]; then
                out_json_error "Invalid timer name: contains forbidden characters" "invalid_name"
            else
                out_error "Invalid timer name '${TIMER_NAME}' (contains forbidden characters)"
            fi
            exit 1
            ;;
    esac
}

timer_domain_fail() {
    # $1=human message  $2=json code  [exit 1]
    local msg="${1-error}"
    local code="${2:-error}"
    if [ "${JSON:-0}" -eq 1 ]; then
        out_json_error "$msg" "$code"
    else
        out_warn "$msg"
    fi
    exit 1
}

timer_start() {
    local mode="volatile"
    [ "${TIMER_PERSIST:-0}" -eq 1 ] && mode="persistent"
    : "${TIMER_FILE:=}"
    : "${TIMER_NAME:=default}"

    if [ -f "$TIMER_FILE" ]; then
        if [ "${JSON}" -eq 1 ]; then
            out_json "error" "Timer '${TIMER_NAME}' is already running." \
                "code" "already_running" \
                "name" "$TIMER_NAME" \
                "mode" "$mode"
        else
            out_warn "Timer '${TIMER_NAME}' is already running."
        fi
        exit 1
    fi

    if ! date +%s > "$TIMER_FILE" 2>/dev/null; then
        timer_domain_fail "Cannot create timer file" "io_error"
    fi

    if [ "${JSON}" -eq 1 ]; then
        out_json "success" "Timer '${TIMER_NAME}' started." \
            "name" "$TIMER_NAME" \
            "mode" "$mode"
    else
        out_success "Timer '${TIMER_NAME}' started."
        if [ "${TIMER_PERSIST}" -eq 1 ]; then
            out_info "  (persistent mode)"
        fi
    fi
    return 0
}

timer_stop() {
    : "${TIMER_FILE:=}"
    : "${TIMER_NAME:=default}"
    if [ ! -f "$TIMER_FILE" ]; then
        timer_domain_fail "No timer '${TIMER_NAME}' running." "no_timer"
    fi

    local start_time current_time elapsed minutes seconds
    start_time=$(cat "$TIMER_FILE" 2>/dev/null)
    rm -f "$TIMER_FILE"

    current_time=$(date +%s)
    elapsed=$((current_time - start_time))
    minutes=$((elapsed / 60))
    seconds=$((elapsed % 60))

    if [ "${JSON}" -eq 1 ]; then
        out_json "success" "Timer '${TIMER_NAME}' stopped after ${minutes} min ${seconds} sec." \
            "name" "$TIMER_NAME" \
            "minutes" "$minutes" \
            "seconds" "$seconds" \
            "elapsed" "$elapsed"
    else
        out_success "Timer '${TIMER_NAME}' stopped after ${minutes} min ${seconds} sec."
    fi
}

timer_status() {
    : "${TIMER_FILE:=}"
    : "${TIMER_NAME:=default}"
    if [ ! -f "$TIMER_FILE" ]; then
        timer_domain_fail "No timer '${TIMER_NAME}' running." "no_timer"
    fi

    local start_time current_time elapsed minutes seconds
    start_time=$(cat "$TIMER_FILE" 2>/dev/null)
    current_time=$(date +%s)
    elapsed=$((current_time - start_time))
    minutes=$((elapsed / 60))
    seconds=$((elapsed % 60))

    if [ "${JSON}" -eq 1 ]; then
        out_json "status" "Timer '${TIMER_NAME}' running." \
            "name" "$TIMER_NAME" \
            "minutes" "$minutes" \
            "seconds" "$seconds" \
            "elapsed" "$elapsed"
    else
        out_plain "Timer '${TIMER_NAME}': ${minutes} min ${seconds} sec"
    fi
}

timer_kill_or_reset() {
    # $1 = kill | reset
    local action="${1-kill}"
    : "${TIMER_FILE:=}"
    : "${TIMER_NAME:=default}"
    if [ ! -f "$TIMER_FILE" ]; then
        timer_domain_fail "No timer '${TIMER_NAME}' running." "no_timer"
    fi
    rm -f "$TIMER_FILE"
    if [ "$action" = "reset" ]; then
        if [ "${JSON}" -eq 1 ]; then
            out_json "success" "Timer '${TIMER_NAME}' has been reset." "name" "$TIMER_NAME"
        else
            out_success "Timer '${TIMER_NAME}' has been reset."
        fi
    else
        if [ "${JSON}" -eq 1 ]; then
            out_json "success" "Timer '${TIMER_NAME}' discarded." "name" "$TIMER_NAME"
        else
            out_warn "Timer '${TIMER_NAME}' discarded."
        fi
    fi
}

timer_list() {
    local requested_mode="${1-volatile}"
    local base_dir count=0 file name start_time current_time elapsed minutes seconds
    local timers_json first
    : "${APP_NAME:=timer}"
    : "${USERNAME:=unknown}"
    : "${JSON:=0}"

    base_dir=$(timer_resolve_base_dir "$requested_mode")

    if [ ! -d "$base_dir" ]; then
        if [ "${JSON}" -eq 1 ]; then
            out_json "list" "" "mode" "$requested_mode" "count" "0" "timers" "[]"
        else
            out_plain "No running timers found."
        fi
        return 0
    fi

    timers_json="["
    first=1
    count=0

    for file in "${base_dir}"/${APP_NAME}_"${USERNAME}"_*; do
        [ -f "$file" ] || continue

        name="${file##*${APP_NAME}_${USERNAME}_}"
        start_time=$(cat "$file" 2>/dev/null) || {
            rm -f "$file" 2>/dev/null || true
            continue
        }

        current_time=$(date +%s 2>/dev/null) || continue
        elapsed=$((current_time - start_time))
        minutes=$((elapsed / 60))
        seconds=$((elapsed % 60))

        if [ "$first" -eq 0 ]; then
            timers_json="${timers_json},"
        fi
        first=0
        timers_json="${timers_json}{\"name\":\"${name}\",\"minutes\":${minutes},\"seconds\":${seconds},\"elapsed\":${elapsed}}"
        count=$((count + 1))
    done
    timers_json="${timers_json}]"

    if [ "${JSON}" -eq 1 ]; then
        # out_json stringifies values (bootstrap SSOT); timers payload is a JSON-text field
        out_json "list" "" \
            "mode" "$requested_mode" \
            "count" "$count" \
            "timers" "$timers_json"
    else
        if [ "$count" -eq 0 ]; then
            out_plain "No running timers found."
        else
            for file in "${base_dir}"/${APP_NAME}_"${USERNAME}"_*; do
                [ -f "$file" ] || continue
                name="${file##*${APP_NAME}_${USERNAME}_}"
                start_time=$(cat "$file" 2>/dev/null) || continue
                current_time=$(date +%s)
                elapsed=$((current_time - start_time))
                minutes=$((elapsed / 60))
                seconds=$((elapsed % 60))
                out_plain "${name} running for ${minutes} min ${seconds} sec"
            done
        fi
    fi
}

app_about() {
    # --- Safe Variable Defaults ---
    : "${JSON:=0}"
    : "${QUIET:=0}"
    : "${APP_NAME:=timer}"
    # Version comes from global SSOT (VERSION="1.0.0" near top); default only if unset
    : "${VERSION:=2.9.0}"
    : "${GLOBAL_BIN:=/usr/local/bin}"
    : "${USER_BIN:=${HOME}/.local/bin}"
    : "${SCRIPT_URL:=}"

    if [ "${JSON}" -eq 1 ]; then
        # === JSON MODE - Clean, machine-friendly output ===
        local installed="false"
        inst_is_installed && installed="true"

        local global_ver="not found"
        if [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; then
            global_ver=$(grep '^VERSION="' "${GLOBAL_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        fi

        local local_ver="not found"
        if [ -x "${USER_BIN}/${APP_NAME}" ]; then
            local_ver=$(grep '^VERSION="' "${USER_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        fi

        local current_shell
        current_shell=$(util_get_current_shell)

        local interactive="false"
        [ -t 1 ] && interactive="true"

        local current_user
        current_user="$(id -un 2>/dev/null || echo "unknown")"

        out_json "about" "" \
            "app" "${APP_NAME}" \
            "version" "${VERSION}" \
            "installed" "${installed}" \
            "global_version" "${global_ver}" \
            "local_version" "${local_ver}" \
            "shell" "${current_shell}" \
            "interactive" "${interactive}" \
            "user" "${current_user}"
        return 0
    fi

    # === Normal Human-readable Mode ===
    [ "${QUIET}" -eq 1 ] && return 0

    out_info "=== ${APP_NAME} ${VERSION} - About / Diagnostics ==="
    out_empty_line

    # Installation status
    if inst_is_installed; then
        out_success "${APP_NAME} is properly installed."
    else
        out_warn "${APP_NAME} is NOT installed in your PATH."
        if [ -n "${SCRIPT_URL}" ]; then
            out_info "   Recommended: curl -fsSL ${SCRIPT_URL} | sh"
        else
            out_info "   Set SCRIPT_URL to the install script URL, then: curl -fsSL \"\${SCRIPT_URL}\" | sh"
        fi
    fi

    out_empty_line

    # Global vs Local installation details
    if [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; then
        global_ver=$(grep '^VERSION="' "${GLOBAL_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        out_info "Global install  (${GLOBAL_BIN}/${APP_NAME}):   ${global_ver}"
    else
        out_info "Global install  (${GLOBAL_BIN}/${APP_NAME}):   not found"
    fi

    if [ -x "${USER_BIN}/${APP_NAME}" ]; then
        local_ver=$(grep '^VERSION="' "${USER_BIN}/${APP_NAME}" 2>/dev/null | cut -d'"' -f2 || echo "unknown")
        out_info "Local install   (${USER_BIN}/${APP_NAME}):    ${local_ver}"
    else
        out_info "Local install   (${USER_BIN}/${APP_NAME}):    not found"
    fi

    out_empty_line

    local current_user
    current_user="$(id -un 2>/dev/null || echo "unknown")"
    out_info "Current user:      ${current_user}"

    if [ "$(id -u)" -eq 0 ]; then
        out_success "Execution context: root (global install path available)"
    else
        out_info "Execution context: normal user (Type 0 CLI self-management)"
    fi

    out_empty_line

    local current_shell
    current_shell=$(util_get_current_shell)

    out_info "Current shell:     ${current_shell}"

    if [ -t 1 ]; then
        out_info "TTY / Interactive: yes"
    else
        out_info "TTY / Interactive: no (non-interactive / scripted mode)"
    fi

    out_empty_line
    out_info "Useful commands:"
    out_info "   ${APP_NAME} start [name]   → Start a timer"
    out_info "   ${APP_NAME} stop [name]    → Stop and show elapsed"
    out_info "   ${APP_NAME} list           → List running timers"
    out_info "   ${APP_NAME} help           → Full usage"
    out_info "   ${APP_NAME} self-update    → Update to latest version"
    out_info "   ${APP_NAME} self-uninstall → Clean removal from system"
    out_info "   ${APP_NAME} --json         → Machine-readable output"

    out_empty_line
    out_info "Run '${APP_NAME} help' for complete usage information."
}

